{
    "name": "kanopi/composer-assets-wordpress-pantheon",
    "description": "Kanopi deployment configuration for WordPress on Pantheon (CircleCI, Kanopi orbs).",
    "type": "library",
    "license": "MIT",
    "keywords": ["kanopi", "wordpress", "pantheon", "circleci", "deployment", "composer-assets"],
    "authors": [
        { "name": "Kanopi Studios" }
    ],
    "require": {
        "kanopi/composer-assets": "^1.2"
    },
    "extra": {
        "composer-assets": {
            "file-mapping": {
                ".circleci/config.yml":                    { "path": "assets/circleci/config.yml", "overwrite": false, "gitignore": false },
                ".circleci/env.sh":                        { "path": "assets/circleci/env.sh", "overwrite": false, "gitignore": false },
                ".circleci/scripts/compile-theme.sh":      { "path": "assets/circleci/scripts/compile-theme.sh", "gitignore": true },
                ".circleci/scripts/pantheon/dev-multidev": { "path": "assets/circleci/scripts/pantheon/dev-multidev", "gitignore": true },
                ".circleci/scripts/pantheon/pre-deploy.sh":  { "path": "assets/circleci/scripts/pantheon/pre-deploy.sh", "overwrite": false, "gitignore": false },
                ".circleci/scripts/pantheon/post-deploy.sh": { "path": "assets/circleci/scripts/pantheon/post-deploy.sh", "overwrite": false, "gitignore": false }
            },
            "conditional": [
                {
                    "if": { "exists": "web" },
                    "file-mapping": {
                        "web/private/scripts/quicksilver/new_relic_deploy.php": { "path": "assets/quicksilver/new_relic_deploy.php", "overwrite": false, "gitignore": false },
                        "web/wp-config.php": { "path": "assets/wordpress/wp-config.php", "overwrite": false, "gitignore": false },
                        "web/wp-config-pantheon.php": { "path": "assets/wordpress/wp-config-pantheon.php", "overwrite": true, "gitignore": false },
                        "web/wp-config-ocp.php": { "path": "assets/wordpress/wp-config-ocp.php", "overwrite": false, "gitignore": false },
                        "pantheon.yml": { "path": "assets/pantheon/web.yml", "overwrite": false, "gitignore": false }
                    }
                },
                {
                    "unless": { "exists": "web" },
                    "file-mapping": {
                        "private/scripts/quicksilver/new_relic_deploy.php": { "path": "assets/quicksilver/new_relic_deploy.php", "overwrite": false, "gitignore": false },
                        "wp-config.php": { "path": "assets/wordpress/wp-config.php", "overwrite": false, "gitignore": false },
                        "wp-config-pantheon.php": { "path": "assets/wordpress/wp-config-pantheon.php", "overwrite": true, "gitignore": false },
                        "wp-config-ocp.php": { "path": "assets/wordpress/wp-config-ocp.php", "overwrite": false, "gitignore": false },
                        "pantheon.yml": { "path": "assets/pantheon/root.yml", "overwrite": false, "gitignore": false }
                    }
                }
            ]
        }
    }
}
